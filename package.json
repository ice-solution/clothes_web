{
  "name": "clothes-wardrobe-qr",
  "version": "1.0.0",
  "private": true,
  "description": "衣櫃 QR 碼：記錄衣物、掃碼瀏覽、以圖搜相似",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/output.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/css/output.css --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "connect-mongo": "^5.1.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.1",
    "express-session": "^1.18.1",
    "mongoose": "^8.8.3",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.7",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15"
  }
}
