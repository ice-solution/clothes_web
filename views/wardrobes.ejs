<%- include('partials/head') %>
  <header class="mb-8">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
      <a href="/" class="text-indigo-300 hover:text-indigo-200">← 首頁</a>
      <span class="text-slate-600">全部衣櫃</span>
    </div>
    <h1 class="mt-3 text-2xl font-bold text-white sm:text-3xl">全部衣櫃</h1>
    <p class="mt-1 text-sm text-slate-400">依建立時間由新到舊排列。已<a href="/login" class="text-indigo-300 hover:text-indigo-200">登入管理員</a>者，點<strong class="text-slate-300">名稱</strong>可進管理頁；否則依本機是否存過 token 決定（否則為公開頁）。「開啟」為公開頁。</p>
  </header>

  <% if (!wardrobes || wardrobes.length === 0) { %>
    <div class="rounded-2xl border border-dashed border-white/15 bg-slate-900/50 px-6 py-14 text-center">
      <p class="text-slate-400">尚無任何衣櫃。</p>
      <a href="/" class="mt-4 inline-block rounded-xl bg-indigo-500 px-5 py-2.5 text-sm font-semibold text-white hover:bg-indigo-400">建立第一個衣櫃</a>
    </div>
  <% } else { %>
    <div class="overflow-x-auto rounded-2xl border border-white/10 bg-white/5 px-4 py-2 shadow-xl backdrop-blur [-webkit-overflow-scrolling:touch] sm:px-6 sm:py-3">
      <table class="w-full min-w-[52rem] table-fixed border-collapse text-sm lg:min-w-0">
        <colgroup>
          <col style="width: 24%" />
          <col style="width: 22%" />
          <col style="width: 5.5rem" />
          <col style="width: 30%" />
          <col style="width: 7.5rem" />
        </colgroup>
        <thead>
          <tr class="border-b border-white/10 bg-slate-900/70">
            <th scope="col" class="py-5 pl-4 pr-4 text-left text-sm font-semibold text-slate-200 sm:pl-5">名稱</th>
            <th scope="col" class="px-4 py-5 text-left text-sm font-semibold text-slate-200">識別碼</th>
            <th scope="col" class="px-4 py-5 text-center text-sm font-semibold text-slate-200">衣物數</th>
            <th scope="col" class="px-4 py-5 text-left text-sm font-semibold text-slate-200">建立時間</th>
            <th scope="col" class="py-5 pl-4 pr-5 text-right text-sm font-semibold text-slate-200 sm:pr-6">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <% wardrobes.forEach(function (w) { %>
            <tr class="align-middle hover:bg-white/[0.03]">
              <td class="py-4 pl-4 pr-4 text-left font-medium sm:py-5 sm:pl-5">
                <div class="flex items-center gap-3 sm:gap-4">
                  <% if (w.coverImageFilename) { %>
                    <button type="button"
                      class="wardrobe-cover-zoom group relative h-16 w-16 shrink-0 overflow-hidden rounded-xl border border-white/15 bg-slate-800 shadow-md ring-0 transition hover:ring-2 hover:ring-indigo-400/60 focus:outline-none focus:ring-2 focus:ring-indigo-400 sm:h-20 sm:w-20"
                      data-lightbox-src="/uploads/<%= w.coverImageFilename %>"
                      data-lightbox-caption="<%= encodeURIComponent(w.name || '衣櫃') %>"
                      title="點擊放大封面"
                      aria-label="放大封面預覽">
                      <img src="/uploads/<%= w.coverImageFilename %>" alt="" class="h-full w-full object-cover transition group-hover:scale-105" />
                      <span class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/0 text-[10px] font-medium text-white opacity-0 transition group-hover:bg-black/35 group-hover:opacity-100">放大</span>
                    </button>
                  <% } else { %>
                    <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-xl border border-dashed border-white/10 bg-slate-900/60 text-[10px] text-slate-600 sm:h-20 sm:w-20" title="尚未上傳封面">無圖</div>
                  <% } %>
                  <a href="<%= typeof loggedIn !== 'undefined' && loggedIn ? '/w/' + w.shortCode + '/manage' : '/w/' + w.shortCode %>"
                    data-manage-code="<%= w.shortCode %>"
                    class="wardrobe-name-link line-clamp-2 min-w-0 flex-1 text-indigo-200 underline-offset-2 hover:text-white hover:underline">
                    <%= w.name || '（未命名）' %>
                  </a>
                </div>
              </td>
              <td class="max-w-0 px-4 py-5 text-left">
                <span class="block truncate font-mono text-xs text-slate-400" title="<%= w.shortCode %>"><%= w.shortCode %></span>
              </td>
              <td class="px-4 py-5 text-center tabular-nums text-base text-slate-200"><%= w.itemCount %></td>
              <td class="whitespace-nowrap px-4 py-5 text-left text-slate-500">
                <% if (w.createdAt) { %>
                  <%= new Date(w.createdAt).toLocaleString('zh-Hant', { dateStyle: 'medium', timeStyle: 'short' }) %>
                <% } else { %>
                  —
                <% } %>
              </td>
              <td class="py-5 pl-4 pr-5 text-right sm:pr-6">
                <a href="/w/<%= w.shortCode %>"
                  class="inline-flex min-h-[2.5rem] min-w-[4.5rem] items-center justify-center rounded-lg bg-indigo-500/90 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-400">
                  開啟
                </a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <p class="mt-4 px-1 text-center text-xs leading-relaxed text-slate-500 sm:px-0">
      公開網址範例：<span class="break-all text-slate-400"><%= baseUrlStr %>/w/&lt;識別碼&gt;</span>
    </p>

    <dialog id="wardrobe-cover-lightbox" class="max-h-[90vh] max-w-[min(96vw,56rem)] rounded-2xl border border-white/10 bg-slate-950 p-0 text-slate-100 shadow-2xl backdrop:bg-black/80 open:flex open:flex-col">
      <div class="flex items-center justify-between gap-2 border-b border-white/10 px-4 py-3">
        <p id="wardrobe-cover-lightbox-caption" class="min-w-0 flex-1 truncate text-sm text-slate-300"></p>
        <button type="button" id="wardrobe-cover-lightbox-close" class="shrink-0 rounded-lg bg-white/10 px-3 py-1.5 text-sm hover:bg-white/20">關閉</button>
      </div>
      <div class="flex max-h-[calc(90vh-4rem)] items-center justify-center overflow-auto p-4">
        <img id="wardrobe-cover-lightbox-img" src="" alt="" class="max-h-[min(75vh,720px)] w-auto max-w-full object-contain" />
      </div>
    </dialog>

    <script>
      (function () {
        var dlg = document.getElementById('wardrobe-cover-lightbox');
        var img = document.getElementById('wardrobe-cover-lightbox-img');
        var cap = document.getElementById('wardrobe-cover-lightbox-caption');
        var btnClose = document.getElementById('wardrobe-cover-lightbox-close');
        if (dlg && img && cap && btnClose) {
          document.querySelectorAll('.wardrobe-cover-zoom').forEach(function (btn) {
            btn.addEventListener('click', function (e) {
              e.preventDefault();
              e.stopPropagation();
              var src = btn.getAttribute('data-lightbox-src');
              var cRaw = btn.getAttribute('data-lightbox-caption') || '';
              var c = cRaw;
              try {
                c = decodeURIComponent(cRaw);
              } catch (err) {}
              if (!src) return;
              img.src = src;
              img.alt = c;
              cap.textContent = c;
              dlg.showModal();
            });
          });
          btnClose.addEventListener('click', function () {
            dlg.close();
          });
          dlg.addEventListener('click', function (e) {
            if (e.target === dlg) dlg.close();
          });
          document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && dlg.open) dlg.close();
          });
        }
      })();
    </script>
    <script>
      (function () {
        var KEY = 'clothesWardrobeManageTokens';
        var map = {};
        var loggedIn = <%- JSON.stringify(typeof loggedIn !== 'undefined' && loggedIn) %>;
        try {
          map = JSON.parse(localStorage.getItem(KEY) || '{}');
        } catch (e) {}
        document.querySelectorAll('a[data-manage-code]').forEach(function (a) {
          var c = a.getAttribute('data-manage-code');
          var tok = c ? map[c] : '';
          if (tok) {
            a.href = '/w/' + encodeURIComponent(c) + '/manage?token=' + encodeURIComponent(tok);
            a.setAttribute('title', '開啟管理／編輯（本機已存 token）');
          } else if (loggedIn) {
            a.href = '/w/' + encodeURIComponent(c) + '/manage';
            a.setAttribute('title', '開啟管理／編輯（已登入）');
          } else {
            a.href = '/w/' + encodeURIComponent(c);
            a.setAttribute('title', '公開瀏覽');
          }
        });
      })();
    </script>
  <% } %>
<%- include('partials/foot') %>
