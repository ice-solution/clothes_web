<%- include('partials/head') %>
  <header class="mb-8">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
      <a href="/" class="text-indigo-300 hover:text-indigo-200">← 首頁</a>
      <span class="text-slate-600">全部衣櫃</span>
    </div>
    <h1 class="mt-3 text-2xl font-bold text-white sm:text-3xl">全部衣櫃</h1>
    <p class="mt-1 text-sm text-slate-400">依建立時間由新到舊排列。已<a href="/login" class="text-indigo-300 hover:text-indigo-200">登入管理員</a>者，點<strong class="text-slate-300">名稱</strong>可進管理頁；否則依本機是否存過 token 決定（否則為公開頁）。「開啟」為公開頁。</p>
  </header>

  <% if (!wardrobes || wardrobes.length === 0) { %>
    <div class="rounded-2xl border border-dashed border-white/15 bg-slate-900/50 px-6 py-14 text-center">
      <p class="text-slate-400">尚無任何衣櫃。</p>
      <a href="/" class="mt-4 inline-block rounded-xl bg-indigo-500 px-5 py-2.5 text-sm font-semibold text-white hover:bg-indigo-400">建立第一個衣櫃</a>
    </div>
  <% } else { %>
    <div class="overflow-x-auto rounded-2xl border border-white/10 bg-white/5 px-4 py-2 shadow-xl backdrop-blur [-webkit-overflow-scrolling:touch] sm:px-6 sm:py-3">
      <table class="w-full min-w-[52rem] table-fixed border-collapse text-sm lg:min-w-0">
        <colgroup>
          <col style="width: 24%" />
          <col style="width: 22%" />
          <col style="width: 5.5rem" />
          <col style="width: 30%" />
          <col style="width: 7.5rem" />
        </colgroup>
        <thead>
          <tr class="border-b border-white/10 bg-slate-900/70">
            <th scope="col" class="py-5 pl-4 pr-4 text-left text-sm font-semibold text-slate-200 sm:pl-5">名稱</th>
            <th scope="col" class="px-4 py-5 text-left text-sm font-semibold text-slate-200">識別碼</th>
            <th scope="col" class="px-4 py-5 text-center text-sm font-semibold text-slate-200">衣物數</th>
            <th scope="col" class="px-4 py-5 text-left text-sm font-semibold text-slate-200">建立時間</th>
            <th scope="col" class="py-5 pl-4 pr-5 text-right text-sm font-semibold text-slate-200 sm:pr-6">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <% wardrobes.forEach(function (w) { %>
            <tr class="align-middle hover:bg-white/[0.03]">
              <td class="py-5 pl-4 pr-4 text-left font-medium sm:pl-5">
                <a href="<%= typeof loggedIn !== 'undefined' && loggedIn ? '/w/' + w.shortCode + '/manage' : '/w/' + w.shortCode %>"
                  data-manage-code="<%= w.shortCode %>"
                  class="wardrobe-name-link line-clamp-2 text-indigo-200 underline-offset-2 hover:text-white hover:underline">
                  <%= w.name || '（未命名）' %>
                </a>
              </td>
              <td class="max-w-0 px-4 py-5 text-left">
                <span class="block truncate font-mono text-xs text-slate-400" title="<%= w.shortCode %>"><%= w.shortCode %></span>
              </td>
              <td class="px-4 py-5 text-center tabular-nums text-base text-slate-200"><%= w.itemCount %></td>
              <td class="whitespace-nowrap px-4 py-5 text-left text-slate-500">
                <% if (w.createdAt) { %>
                  <%= new Date(w.createdAt).toLocaleString('zh-Hant', { dateStyle: 'medium', timeStyle: 'short' }) %>
                <% } else { %>
                  —
                <% } %>
              </td>
              <td class="py-5 pl-4 pr-5 text-right sm:pr-6">
                <a href="/w/<%= w.shortCode %>"
                  class="inline-flex min-h-[2.5rem] min-w-[4.5rem] items-center justify-center rounded-lg bg-indigo-500/90 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-400">
                  開啟
                </a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <p class="mt-4 px-1 text-center text-xs leading-relaxed text-slate-500 sm:px-0">
      公開網址範例：<span class="break-all text-slate-400"><%= baseUrlStr %>/w/&lt;識別碼&gt;</span>
    </p>
    <script>
      (function () {
        var KEY = 'clothesWardrobeManageTokens';
        var map = {};
        var loggedIn = <%- JSON.stringify(typeof loggedIn !== 'undefined' && loggedIn) %>;
        try {
          map = JSON.parse(localStorage.getItem(KEY) || '{}');
        } catch (e) {}
        document.querySelectorAll('a[data-manage-code]').forEach(function (a) {
          var c = a.getAttribute('data-manage-code');
          var tok = c ? map[c] : '';
          if (tok) {
            a.href = '/w/' + encodeURIComponent(c) + '/manage?token=' + encodeURIComponent(tok);
            a.setAttribute('title', '開啟管理／編輯（本機已存 token）');
          } else if (loggedIn) {
            a.href = '/w/' + encodeURIComponent(c) + '/manage';
            a.setAttribute('title', '開啟管理／編輯（已登入）');
          } else {
            a.href = '/w/' + encodeURIComponent(c);
            a.setAttribute('title', '公開瀏覽');
          }
        });
      })();
    </script>
  <% } %>
<%- include('partials/foot') %>
