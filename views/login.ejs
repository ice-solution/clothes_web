<%- include('partials/head') %>
  <header class="mb-8 text-center">
    <a href="/" class="text-sm text-indigo-300 hover:text-indigo-200">← 首頁</a>
    <h1 class="mt-4 text-2xl font-bold text-white sm:text-3xl">管理員登入</h1>
    <p class="mt-2 text-sm text-slate-400">登入後可編輯任意衣櫃，無需 token 連結。</p>
  </header>

  <div class="mx-auto max-w-md rounded-2xl border border-white/10 bg-white/5 p-6 shadow-xl backdrop-blur sm:p-8">
    <% if (typeof error !== 'undefined' && error) { %>
      <p class="mb-4 rounded-lg border border-red-500/40 bg-red-950/50 px-3 py-2 text-sm text-red-200"><%= error %></p>
    <% } %>
    <form action="/login" method="post" class="space-y-4">
      <input type="hidden" name="next" value="<%= typeof next !== 'undefined' ? next : '' %>" />
      <div>
        <label for="username" class="block text-sm font-medium text-slate-300">帳號</label>
        <input type="text" id="username" name="username" required autocomplete="username" maxlength="64"
          value="<%= typeof username !== 'undefined' ? username : '' %>"
          class="mt-1.5 w-full rounded-xl border border-white/10 bg-slate-900/80 px-4 py-2.5 text-white placeholder:text-slate-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/40" />
      </div>
      <div>
        <label for="password" class="block text-sm font-medium text-slate-300">密碼</label>
        <input type="password" id="password" name="password" required autocomplete="current-password" maxlength="128"
          class="mt-1.5 w-full rounded-xl border border-white/10 bg-slate-900/80 px-4 py-2.5 text-white placeholder:text-slate-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/40" />
      </div>
      <button type="submit"
        class="w-full rounded-xl bg-indigo-500 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 hover:bg-indigo-400">
        登入
      </button>
    </form>
  </div>
<%- include('partials/foot') %>
