<%- include('partials/head') %>
  <div class="mx-auto max-w-md rounded-2xl border border-red-500/30 bg-red-950/40 p-8 text-center">
    <p class="text-sm font-medium text-red-300/90">發生問題</p>
    <h1 class="mt-2 text-xl font-bold text-white"><%= typeof title !== 'undefined' ? title : '錯誤' %></h1>
    <% if (typeof messageHtml !== 'undefined' && messageHtml) { %>
      <div class="mt-3 text-slate-300"><%- messageHtml %></div>
    <% } else if (typeof message !== 'undefined' && message) { %>
      <p class="mt-3 text-slate-300"><%= message %></p>
    <% } %>
    <a href="/" class="mt-6 inline-block rounded-xl bg-white/10 px-5 py-2 text-sm font-medium text-white hover:bg-white/15">返回首頁</a>
  </div>
<%- include('partials/foot') %>
