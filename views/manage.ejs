<%- include('partials/head') %>
  <header class="mb-8">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
      <a href="/" class="text-indigo-300 hover:text-indigo-200">← 首頁</a>
      <a href="/wardrobes" class="text-slate-400 hover:text-slate-300">全部衣櫃</a>
    </div>
    <h1 class="mt-3 text-2xl font-bold text-white sm:text-3xl" id="manage-wardrobe-title">管理 · <%= wardrobe.name %></h1>
    <p class="mt-1 text-sm text-slate-400">請勿分享下方「管理連結」；QR 碼僅用於瀏覽衣櫃內容。</p>
  </header>

  <section class="mb-10 rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur">
    <h2 class="text-lg font-semibold text-white">衣櫃設定</h2>
    <p class="mt-1 text-sm text-slate-400">更改衣櫃顯示名稱、上傳或更換封面圖（公開頁與列表會顯示）。</p>
    <!-- Grid 避免 flex 子項被壓成極窄導致文字直排；中屏以上：左預覽固定寬、右表單自適應 -->
    <div class="mt-6 grid w-full grid-cols-1 gap-6 md:grid-cols-[11rem_minmax(0,1fr)] md:gap-8 md:items-start">
      <div id="wardrobe-cover-preview" class="relative mx-auto aspect-square w-full max-w-[11rem] overflow-hidden rounded-xl border border-white/10 bg-slate-800 md:mx-0 md:max-w-none md:w-[11rem]">
        <% if (wardrobe.coverImageFilename) { %>
          <img src="/uploads/<%= wardrobe.coverImageFilename %>" alt="" class="h-full w-full object-cover" />
        <% } else { %>
          <div class="flex h-full min-h-[8rem] w-full items-center justify-center px-2 text-center text-xs leading-relaxed text-slate-500">尚無封面</div>
        <% } %>
      </div>
      <div class="w-full min-w-0 space-y-4">
        <div class="min-w-0">
          <label for="wardrobe-name" class="mb-1 block text-sm font-medium text-slate-300">衣櫃名稱</label>
          <input type="text" id="wardrobe-name" maxlength="80" value="<%= wardrobe.name %>"
            class="box-border w-full max-w-full rounded-xl border border-white/10 bg-slate-900/80 px-4 py-2.5 text-left text-base text-white placeholder:text-slate-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/40" />
        </div>
        <div class="min-w-0">
          <label for="wardrobe-cover" class="mb-1 block text-sm font-medium text-slate-300">封面圖片（選填）</label>
          <input type="file" id="wardrobe-cover" accept="image/*"
            class="box-border block w-full max-w-full min-w-0 text-sm text-slate-300 file:mr-3 file:rounded-lg file:border-0 file:bg-indigo-500 file:px-4 file:py-2 file:text-sm file:font-medium file:text-white" />
          <p class="mt-2 text-xs leading-relaxed text-slate-500">上傳新圖會取代舊封面。</p>
        </div>
        <div class="flex flex-wrap items-center gap-3 pt-1">
          <button type="button" id="wardrobe-save-btn"
            class="shrink-0 rounded-xl bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-indigo-500">儲存衣櫃設定</button>
          <span id="wardrobe-save-msg" class="hidden text-sm text-emerald-400"></span>
        </div>
      </div>
    </div>
  </section>

  <div class="grid gap-8 lg:grid-cols-2">
    <section class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur">
      <h2 class="text-lg font-semibold text-white">衣櫃 QR（掃碼瀏覽）</h2>
      <p class="mt-1 text-xs text-slate-500 break-all">公開連結：<span class="text-slate-400"><%= listUrl %></span></p>
      <% if (qrDataUrl) { %>
        <div class="mt-4 flex justify-center rounded-xl bg-white p-4">
          <img src="<%= qrDataUrl %>" alt="衣櫃 QR" class="h-48 w-48" />
        </div>
      <% } %>
      <div class="mt-4 flex flex-wrap gap-2">
        <a href="/w/<%= wardrobe.shortCode %>/qr.png" download="wardrobe-<%= wardrobe.shortCode %>.png"
          class="rounded-lg bg-white/10 px-3 py-1.5 text-sm text-white hover:bg-white/15">下載 QR PNG</a>
        <a href="<%= listUrl %>" target="_blank" rel="noopener"
          class="rounded-lg bg-indigo-500/80 px-3 py-1.5 text-sm text-white hover:bg-indigo-400">預覽公開頁</a>
      </div>
    </section>

    <section class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur">
      <h2 class="text-lg font-semibold text-white">管理連結（請自行備份）</h2>
      <% if (typeof sessionAuth !== 'undefined' && sessionAuth) { %>
        <p class="mt-2 text-xs text-emerald-200/90">您已以管理員登入，可直接編輯。若需給他人獨立管理權限，請複製下方完整連結（含 token）。</p>
        <% if (typeof shareManageUrl !== 'undefined' && shareManageUrl) { %>
          <p class="mt-3 break-all rounded-lg bg-slate-900/80 p-3 text-xs text-indigo-200"><%= shareManageUrl %></p>
        <% } %>
      <% } else { %>
        <p class="mt-2 break-all rounded-lg bg-slate-900/80 p-3 text-xs text-indigo-200"><%= baseUrlStr %>/w/<%= wardrobe.shortCode %>/manage?token=***</p>
        <p class="mt-2 text-xs text-amber-200/90">若遺失管理連結，可使用<a href="/login" class="font-medium text-amber-100 underline">管理員登入</a>後從「全部衣櫃」進入編輯。</p>
      <% } %>
    </section>
  </div>

  <section class="mt-10 rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur">
    <h2 class="text-lg font-semibold text-white">新增衣物</h2>
    <form action="/api/w/<%= wardrobe.shortCode %>/items" method="post" enctype="multipart/form-data" class="mt-4 space-y-4">
      <% if (!(typeof sessionAuth !== 'undefined' && sessionAuth)) { %>
        <input type="hidden" name="editToken" value="<%= editToken %>" />
      <% } %>
      <div>
        <label class="block text-sm font-medium text-slate-300">照片 <span class="text-red-400">*</span></label>
        <p class="mt-0.5 text-xs text-slate-500">可一次選多張（按住 Shift／Cmd 或 Ctrl 多選），每張會各建立一筆衣物；下方描述與放置位置會套用到每一張。</p>
        <input type="file" name="image" accept="image/*" multiple required
          class="mt-2 block w-full text-sm text-slate-300 file:mr-3 file:rounded-lg file:border-0 file:bg-indigo-500 file:px-4 file:py-2 file:text-sm file:font-medium file:text-white" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-300">放置位置（選填）</label>
        <input type="text" name="position" maxlength="120" placeholder="例如：上層左側、抽屜 B"
          class="mt-1 w-full rounded-xl border border-white/10 bg-slate-900/80 px-4 py-2.5 text-white placeholder:text-slate-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/40" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-300">描述（選填）</label>
        <textarea name="description" rows="3" maxlength="500" placeholder="顏色、材質、季節…"
          class="mt-1 w-full rounded-xl border border-white/10 bg-slate-900/80 px-4 py-2.5 text-white placeholder:text-slate-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/40"></textarea>
      </div>
      <button type="submit" class="rounded-xl bg-emerald-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-emerald-500">加入衣櫃（多張會一次全部上傳）</button>
    </form>
  </section>

  <section class="mt-10">
    <h2 class="mb-4 text-lg font-semibold text-white">已存放衣物（<%= items.length %>）</h2>
    <% if (items.length === 0) { %>
      <p class="text-slate-500">尚無項目。</p>
    <% } else { %>
      <ul class="space-y-6">
        <% items.forEach(function (item) { %>
          <li class="rounded-2xl border border-white/10 bg-slate-900/50 p-4" data-item-id="<%= item._id %>">
            <div class="flex flex-col gap-4 sm:flex-row">
              <div class="h-40 w-full shrink-0 overflow-hidden rounded-xl bg-slate-800 sm:h-32 sm:w-32">
                <img src="/uploads/<%= item.imageFilename %>" alt="" class="h-full w-full object-cover" />
              </div>
              <div class="min-w-0 flex-1 space-y-3">
                <div>
                  <label class="text-xs text-slate-500">放置位置</label>
                  <input type="text" data-field="position" value="<%= item.position || '' %>"
                    class="item-input mt-0.5 w-full rounded-lg border border-white/10 bg-slate-950/80 px-3 py-2 text-sm text-white" />
                </div>
                <div>
                  <label class="text-xs text-slate-500">描述</label>
                  <textarea data-field="description" rows="2"
                    class="item-input mt-0.5 w-full rounded-lg border border-white/10 bg-slate-950/80 px-3 py-2 text-sm text-white"><%= item.description || '' %></textarea>
                </div>
                <div>
                  <label class="text-xs text-slate-500">更換照片（選填）</label>
                  <input type="file" data-field="image" accept="image/*"
                    class="mt-0.5 block w-full text-xs text-slate-300 file:mr-2 file:rounded file:bg-white/10 file:px-2 file:py-1 file:text-white" />
                </div>
                <div class="flex flex-wrap gap-2">
                  <button type="button" data-save class="rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-indigo-500">儲存變更</button>
                  <button type="button" data-delete class="rounded-lg bg-red-600/90 px-3 py-1.5 text-xs font-medium text-white hover:bg-red-500">刪除</button>
                  <span data-msg class="hidden text-xs text-emerald-400"></span>
                </div>
              </div>
            </div>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </section>

  <script>
    (function () {
      const code = <%- JSON.stringify(wardrobe.shortCode) %>;
      const token = <%- JSON.stringify(editToken || '') %>;
      const sessionAuth = <%- JSON.stringify(typeof sessionAuth !== 'undefined' && sessionAuth) %>;

      document.getElementById('wardrobe-save-btn').addEventListener('click', async function () {
        const msg = document.getElementById('wardrobe-save-msg');
        const nameInput = document.getElementById('wardrobe-name');
        const fileInput = document.getElementById('wardrobe-cover');
        const preview = document.getElementById('wardrobe-cover-preview');
        const titleEl = document.getElementById('manage-wardrobe-title');
        msg.classList.add('hidden');
        const fd = new FormData();
        if (!sessionAuth && token) fd.append('editToken', token);
        fd.append('name', nameInput.value);
        if (fileInput.files && fileInput.files[0]) fd.append('cover', fileInput.files[0]);
        try {
          const res = await fetch('/api/w/' + encodeURIComponent(code) + '/wardrobe', {
            method: 'PUT',
            credentials: 'same-origin',
            body: fd,
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || '儲存失敗');
          msg.textContent = '已儲存';
          msg.classList.remove('hidden');
          msg.classList.remove('text-red-400');
          msg.classList.add('text-emerald-400');
          if (titleEl) titleEl.textContent = '管理 · ' + (data.name || nameInput.value);
          if (data.coverImageFilename && preview) {
            preview.innerHTML = '';
            var im = document.createElement('img');
            im.src = '/uploads/' + data.coverImageFilename;
            im.alt = '';
            im.className = 'h-full w-full object-cover';
            preview.appendChild(im);
          }
          fileInput.value = '';
        } catch (e) {
          msg.textContent = e.message || '錯誤';
          msg.classList.remove('hidden');
          msg.classList.remove('text-emerald-400');
          msg.classList.add('text-red-400');
        }
      });

      document.querySelectorAll('[data-item-id]').forEach(function (row) {
        const id = row.getAttribute('data-item-id');
        const msg = row.querySelector('[data-msg]');

        row.querySelector('[data-save]').addEventListener('click', async function () {
          msg.classList.add('hidden');
          const fd = new FormData();
          if (!sessionAuth && token) fd.append('editToken', token);
          fd.append('description', row.querySelector('[data-field="description"]').value);
          fd.append('position', row.querySelector('[data-field="position"]').value);
          const fileInput = row.querySelector('[data-field="image"]');
          if (fileInput.files && fileInput.files[0]) fd.append('image', fileInput.files[0]);
          try {
            const res = await fetch('/api/w/' + encodeURIComponent(code) + '/items/' + encodeURIComponent(id), {
              method: 'PUT',
              credentials: 'same-origin',
              body: fd,
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || '儲存失敗');
            msg.textContent = '已儲存';
            msg.classList.remove('hidden');
            fileInput.value = '';
          } catch (e) {
            msg.textContent = e.message || '錯誤';
            msg.classList.remove('hidden');
            msg.classList.remove('text-emerald-400');
            msg.classList.add('text-red-400');
          }
        });

        row.querySelector('[data-delete]').addEventListener('click', async function () {
          if (!confirm('確定刪除此衣物？')) return;
          msg.classList.add('hidden');
          try {
            const res = await fetch('/api/w/' + encodeURIComponent(code) + '/items/' + encodeURIComponent(id), {
              method: 'DELETE',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(sessionAuth ? {} : { editToken: token }),
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || '刪除失敗');
            row.remove();
          } catch (e) {
            alert(e.message || '錯誤');
          }
        });
      });
    })();
  </script>
  <script>
    (function () {
      var m = location.pathname.match(/^\/w\/([^/]+)\/manage$/);
      var t = new URLSearchParams(location.search).get('token');
      if (!m || !t) return;
      try {
        var KEY = 'clothesWardrobeManageTokens';
        var o = JSON.parse(localStorage.getItem(KEY) || '{}');
        o[m[1]] = t;
        localStorage.setItem(KEY, JSON.stringify(o));
      } catch (e) {}
    })();
  </script>
<%- include('partials/foot') %>
