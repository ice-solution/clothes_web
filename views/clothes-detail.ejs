<%- include('partials/head') %>
  <% var w = item.wardrobeId; %>
  <header class="mb-8">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
      <a href="/clothes" class="text-indigo-300 hover:text-indigo-200">← 所有衣服</a>
      <% if (w && w.shortCode) { %>
        <a href="/w/<%= w.shortCode %>" class="text-slate-400 hover:text-slate-300">所屬衣櫃公開頁</a>
      <% } %>
    </div>
    <h1 class="mt-3 text-xl font-bold text-white sm:text-2xl">衣物詳情</h1>
  </header>

  <article class="overflow-hidden rounded-2xl border border-white/10 bg-white/5 shadow-xl backdrop-blur">
    <div class="mx-auto max-w-lg bg-slate-900/40">
      <img src="/uploads/<%= item.imageFilename %>" alt="" class="w-full object-contain" />
    </div>
    <div class="space-y-4 p-6">
      <dl class="grid gap-3 text-sm sm:grid-cols-2">
        <div class="rounded-xl border border-white/5 bg-slate-900/40 px-4 py-3">
          <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">上傳時間</dt>
          <dd class="mt-1 text-slate-200">
            <% if (item.createdAt) { %>
              <%= new Date(item.createdAt).toLocaleString('zh-Hant', { dateStyle: 'full', timeStyle: 'short' }) %>
            <% } else { %>
              —
            <% } %>
          </dd>
        </div>
        <div class="rounded-xl border border-white/5 bg-slate-900/40 px-4 py-3">
          <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">所屬衣櫃</dt>
          <dd class="mt-1 text-slate-200">
            <% if (w && w.name && w.shortCode) { %>
              <a href="/w/<%= w.shortCode %>" class="font-medium text-indigo-300 hover:text-indigo-200"><%= w.name %></a>
              <span class="mt-1 block font-mono text-xs text-slate-500"><%= w.shortCode %></span>
            <% } else { %>
              <span class="text-slate-500">衣櫃已不存在或已刪除</span>
            <% } %>
          </dd>
        </div>
      </dl>
      <% if (item.position) { %>
        <p class="text-sm text-slate-400"><span class="text-slate-500">放置位置：</span><%= item.position %></p>
      <% } %>
      <% if (item.description) { %>
        <div class="rounded-xl border border-white/5 bg-slate-900/40 px-4 py-3">
          <p class="text-xs font-medium text-slate-500">描述</p>
          <p class="mt-1 whitespace-pre-wrap text-sm text-slate-200"><%= item.description %></p>
        </div>
      <% } %>
    </div>
  </article>
<%- include('partials/foot') %>
